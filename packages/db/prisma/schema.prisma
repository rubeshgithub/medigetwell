generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(PATIENT)
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  bookings      Booking[]
  clinics       Clinic[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  PATIENT
  CLINIC_OWNER
  ADMIN
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ CLINICS ============

model Clinic {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?  @db.Text
  phone           String?
  email           String?
  website         String?
  address         String
  city            String
  province        String
  postalCode      String?
  latitude        Float?
  longitude       Float?
  rating          Float?   @default(0)
  reviewCount     Int      @default(0)
  imageUrl        String?
  logoUrl         String?
  isVerified      Boolean  @default(false)
  isActive        Boolean  @default(true)
  waitTimeMinutes Int?
  acceptsWalkIns  Boolean  @default(true)
  acceptsBookings Boolean  @default(false)
  clinicOwnerId   String?
  clinicOwner     User?    @relation(fields: [clinicOwnerId], references: [id])
  specialties     ClinicSpecialty[]
  services        ClinicService[]
  languages       ClinicLanguage[]
  hours           ClinicHour[]
  reviews         Review[]
  bookings        Booking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city, province])
  @@index([slug])
}

model ClinicHour {
  id        String  @id @default(cuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean @default(false)

  @@unique([clinicId, dayOfWeek])
}

// ============ SPECIALTIES ============

model Specialty {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?            @db.Text
  imageUrl    String?
  iconEmoji   String?
  clinics     ClinicSpecialty[]
  createdAt   DateTime           @default(now())

  @@index([slug])
}

model ClinicSpecialty {
  clinicId    String
  specialtyId String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([clinicId, specialtyId])
}

// ============ SERVICES ============

model Service {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?         @db.Text
  iconEmoji   String?
  clinics     ClinicService[]
  createdAt   DateTime        @default(now())

  @@index([slug])
}

model ClinicService {
  clinicId  String
  serviceId String
  clinic    Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([clinicId, serviceId])
}

// ============ SYMPTOMS ============

model Symptom {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  bodyPart    String?
  severity    String?
  createdAt   DateTime @default(now())

  @@index([slug])
}

// ============ LANGUAGES ============

model Language {
  id      String           @id @default(cuid())
  name    String           @unique
  code    String           @unique
  clinics ClinicLanguage[]
}

model ClinicLanguage {
  clinicId   String
  languageId String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([clinicId, languageId])
}

// ============ REVIEWS ============

model Review {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  title      String?
  body       String?  @db.Text
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clinicId])
}

// ============ BOOKINGS ============

model Booking {
  id          String        @id @default(cuid())
  clinicId    String
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  time        String
  status      BookingStatus @default(PENDING)
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ============ BLOG / POSTS ============

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  authorName  String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished, publishedAt])
}
